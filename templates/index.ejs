<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title><%= settings.logo_text %> - Carpinteria & Diseno de Muebles</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '#000000',
            accent: '#1a1a1a',
            light: '#f5f5f5',
          },
          fontFamily: {
            heading: ['"Playfair Display"', 'serif'],
            body: ['"Inter"', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-heading { font-family: 'Playfair Display', serif; }
    .card-hover:hover { transform: translateY(-8px); }
    .fade-in { animation: fadeIn 0.8s ease-out forwards; opacity: 0; }
    @keyframes fadeIn { to { opacity: 1; } }
    .slide-up { animation: slideUp 0.8s ease-out forwards; opacity: 0; transform: translateY(30px); }
    @keyframes slideUp { to { opacity: 1; transform: translateY(0); } }

    /* Rich content from WYSIWYG editor */
    .rich-content { word-break: break-word; overflow-wrap: break-word; }
    .rich-content p { margin: 0; }
    .rich-content strong { font-weight: 700; }
    .rich-content em { font-style: italic; }
    .rich-content u { text-decoration: underline; }
    .rich-content h1, .rich-content h2, .rich-content h3 { font-family: 'Playfair Display', serif; font-weight: 700; margin: 0.5em 0; }
    .rich-content ul { list-style: disc; padding-left: 1.5em; }
    .rich-content ol { list-style: decimal; padding-left: 1.5em; }
    .rich-content a { text-decoration: underline; }

    /* Mobile enhancements */
    @media (max-width: 767px) {
      .hero-section { min-height: 100svh; }
      #galleryCarousel { border-radius: 12px; }
      section { padding-top: 4rem; padding-bottom: 4rem; }
    }
  </style>
</head>
<body class="bg-white text-black">

  <!-- Navbar -->
  <nav id="navbar" class="fixed top-0 w-full z-50 transition-all duration-300 bg-transparent">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="#" class="flex items-center">
        <% if (settings.logo_image) { %>
          <img src="<%= settings.logo_image %>" alt="<%= settings.logo_text %>" class="h-8 md:h-10 w-auto" />
        <% } else { %>
          <span class="text-xl md:text-2xl font-heading font-bold text-white tracking-widest"><%= settings.logo_text %></span>
        <% } %>
      </a>
      <div class="hidden md:flex items-center gap-8">
        <% settings.nav_items.forEach(function(item, index) { %>
          <% if (index === settings.nav_items.length - 1) { %>
            <a href="<%= item.href %>" class="bg-white text-black px-6 py-2 text-sm tracking-wider uppercase hover:bg-gray-200 transition"><%= item.label %></a>
          <% } else { %>
            <a href="<%= item.href %>" class="text-white/80 hover:text-white transition text-sm tracking-wider uppercase"><%= item.label %></a>
          <% } %>
        <% }); %>
      </div>
      <button id="menuBtn" class="md:hidden text-white">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobileMenu" class="hidden md:hidden bg-black/95 backdrop-blur-sm">
      <div class="px-6 py-4 flex flex-col gap-4">
        <% settings.nav_items.forEach(function(item) { %>
          <a href="<%= item.href %>" class="text-white/80 hover:text-white transition text-sm tracking-wider uppercase py-2"><%= item.label %></a>
        <% }); %>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section id="inicio" class="hero-section min-h-screen flex items-center justify-center text-white relative overflow-hidden" style="background: linear-gradient(135deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.6) 100%), url('<%= hero.background_image %>') center/cover no-repeat;">
    <div class="max-w-4xl mx-auto text-center px-6 fade-in">
      <p class="text-sm md:text-base tracking-[0.4em] uppercase mb-6 text-white/70"><%= hero.subtitle %></p>
      <h1 class="font-heading text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-bold leading-tight mb-6 md:mb-8">
        <%= hero.headline_line1 %> <br/><span class="italic font-light"><%= hero.headline_line2 %></span>
      </h1>
      <div class="text-base md:text-xl text-white/70 max-w-2xl mx-auto mb-8 md:mb-10 font-light leading-relaxed px-2 rich-content">
        <%- hero.description %>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="<%= hero.cta_primary_link %>" class="bg-white text-black px-10 py-4 text-sm tracking-widest uppercase hover:bg-gray-200 transition font-medium">
          <%= hero.cta_primary_text %>
        </a>
        <a href="<%= hero.cta_secondary_link %>" class="border border-white/40 text-white px-10 py-4 text-sm tracking-widest uppercase hover:bg-white/10 transition font-medium">
          <%= hero.cta_secondary_text %>
        </a>
      </div>
    </div>
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-black text-white py-12">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <% stats.forEach(function(stat) { %>
        <div>
          <p class="text-3xl md:text-4xl font-heading font-bold"><%= stat.number %></p>
          <p class="text-xs tracking-widest uppercase text-white/60 mt-2"><%= stat.label %></p>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- About -->
  <section id="nosotros" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div>
        <p class="text-xs tracking-[0.3em] uppercase text-black/40 mb-4"><%= about.section_label %></p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6 md:mb-8 leading-tight">
          <%= about.headline %>
        </h2>
        <div class="text-gray-600 leading-relaxed mb-6 rich-content">
          <%- about.paragraph1 %>
        </div>
        <div class="text-gray-600 leading-relaxed mb-8 rich-content">
          <%- about.paragraph2 %>
        </div>
        <div class="flex flex-wrap gap-6 md:gap-8">
          <% about.benefits.forEach(function(benefit) { %>
            <div>
              <div class="w-12 h-12 bg-black rounded-full flex items-center justify-center mb-3">
                <% if (benefit.icon === 'check') { %>
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <% } else if (benefit.icon === 'clock') { %>
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <% } else if (benefit.icon === 'heart') { %>
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
                <% } %>
              </div>
              <p class="text-sm font-medium"><%= benefit.label %></p>
            </div>
          <% }); %>
        </div>
      </div>
      <div class="relative">
        <div class="bg-gray-100 aspect-[4/5] overflow-hidden">
          <img src="<%= about.image %>" alt="<%= about.headline %>" class="w-full h-full object-cover" />
        </div>
        <div class="absolute -bottom-6 -left-6 bg-black text-white p-8 max-w-[200px]">
          <p class="font-heading text-3xl font-bold"><%= about.overlay_number %></p>
          <p class="text-xs tracking-widest uppercase text-white/70 mt-1"><%= about.overlay_text %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="servicios" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-black/40 mb-4">Nuestros servicios</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold">Lo que hacemos</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <% services.forEach(function(service) { %>
          <div class="bg-white p-10 card-hover transition-all duration-300 group border border-transparent hover:border-black">
            <div class="w-16 h-16 bg-black text-white flex items-center justify-center mb-6 group-hover:bg-white group-hover:text-black group-hover:border group-hover:border-black transition-all">
              <% if (service.icon === 'home') { %>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4"/></svg>
              <% } else if (service.icon === 'building') { %>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              <% } else if (service.icon === 'puzzle') { %>
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"/></svg>
              <% } %>
            </div>
            <h3 class="font-heading text-xl font-bold mb-4"><%= service.title %></h3>
            <div class="text-gray-500 leading-relaxed text-sm rich-content">
              <%- service.description %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="galeria" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-black/40 mb-4">Nuestro trabajo</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold">Galeria de Proyectos</h2>
      </div>

      <!-- Mobile: Carousel -->
      <div class="md:hidden relative">
        <div id="galleryCarousel" class="overflow-hidden relative">
          <div id="galleryTrack" class="flex transition-transform duration-500 ease-in-out">
            <% gallery.forEach(function(item) { %>
              <div class="w-full flex-shrink-0 px-2">
                <div class="relative overflow-hidden aspect-[4/3] rounded-lg">
                  <img src="<%= item.image %>" alt="<%= item.title %>" class="w-full h-full object-cover" />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-6">
                    <div>
                      <p class="text-white/70 text-xs tracking-widest uppercase mb-1"><%= item.category %></p>
                      <h3 class="text-white font-heading text-xl font-bold"><%= item.title %></h3>
                    </div>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        </div>
        <!-- Carousel Controls -->
        <div class="flex items-center justify-center gap-6 mt-6">
          <button id="prevBtn" class="w-12 h-12 bg-black text-white flex items-center justify-center hover:bg-gray-800 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <div id="galleryDots" class="flex gap-2"></div>
          <button id="nextBtn" class="w-12 h-12 bg-black text-white flex items-center justify-center hover:bg-gray-800 transition">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
        <!-- Counter -->
        <p id="galleryCounter" class="text-center text-xs tracking-widest uppercase text-black/40 mt-3">1 / <%= gallery.length %></p>
      </div>

      <!-- Desktop: Grid -->
      <div class="hidden md:grid md:grid-cols-3 gap-4">
        <% gallery.forEach(function(item, index) { %>
          <% if (index === 0) { %>
            <div class="group relative overflow-hidden aspect-square md:col-span-2 md:row-span-2">
              <img src="<%= item.image %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-500 flex items-end p-8">
                <div class="translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                  <p class="text-white/70 text-xs tracking-widest uppercase mb-2"><%= item.category %></p>
                  <h3 class="text-white font-heading text-2xl font-bold"><%= item.title %></h3>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="group relative overflow-hidden aspect-square">
              <img src="<%= item.image %>" alt="<%= item.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/60 transition-all duration-500 flex items-end p-6">
                <div class="translate-y-8 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
                  <p class="text-white/70 text-xs tracking-widest uppercase mb-2"><%= item.category %></p>
                  <h3 class="text-white font-heading text-lg font-bold"><%= item.title %></h3>
                </div>
              </div>
            </div>
          <% } %>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section id="proceso" class="py-24 bg-black text-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-white/40 mb-4">Como trabajamos</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold">Nuestro Proceso</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        <% process_steps.forEach(function(step) { %>
          <div class="text-center group">
            <div class="w-20 h-20 mx-auto border border-white/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-white group-hover:text-black transition-all duration-300">
              <span class="font-heading text-2xl font-bold"><%= step.step_number %></span>
            </div>
            <h3 class="font-heading text-lg font-bold mb-3"><%= step.title %></h3>
            <div class="text-white/50 text-sm leading-relaxed rich-content"><%- step.description %></div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <p class="text-xs tracking-[0.3em] uppercase text-black/40 mb-4">Testimonios</p>
        <h2 class="font-heading text-3xl md:text-5xl font-bold">Lo que dicen nuestros clientes</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <% testimonials.forEach(function(testimonial) { %>
          <div class="bg-white p-10 border border-gray-100">
            <div class="flex gap-1 mb-6">
              <% for (var i = 0; i < testimonial.rating; i++) { %>
                <svg class="w-5 h-5 text-black" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              <% } %>
            </div>
            <div class="text-gray-600 text-sm leading-relaxed mb-6 italic rich-content">
              "<%- testimonial.quote %>"
            </div>
            <div>
              <p class="font-medium text-sm"><%= testimonial.author %></p>
              <p class="text-xs text-gray-400"><%= testimonial.context %></p>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="py-24 bg-black text-white">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6">
        <%= cta.headline %>
      </h2>
      <div class="text-white/60 text-lg mb-10 max-w-2xl mx-auto rich-content">
        <%- cta.description %>
      </div>
      <a href="<%= cta.button_link %>" class="inline-block bg-white text-black px-12 py-4 text-sm tracking-widest uppercase hover:bg-gray-200 transition font-medium">
        <%= cta.button_text %>
      </a>
    </div>
  </section>

  <!-- Contact -->
  <section id="contacto" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <p class="text-xs tracking-[0.3em] uppercase text-black/40 mb-4"><%= contact.section_label %></p>
          <h2 class="font-heading text-3xl md:text-5xl font-bold mb-6 md:mb-8"><%= contact.headline %></h2>
          <div class="text-gray-500 leading-relaxed mb-10 rich-content">
            <%- contact.description %>
          </div>
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <p class="font-medium text-sm">Direccion</p>
                <p class="text-gray-400 text-sm"><%= contact.address %></p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <p class="font-medium text-sm">Telefono</p>
                <p class="text-gray-400 text-sm"><%= contact.phone %></p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="font-medium text-sm">Email</p>
                <p class="text-gray-400 text-sm"><%= contact.email %></p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-black text-white flex items-center justify-center flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              </div>
              <div>
                <p class="font-medium text-sm">Horario</p>
                <p class="text-gray-400 text-sm"><%= contact.hours %></p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <form class="space-y-6" method="POST" action="/api/contact">
            <div class="grid grid-cols-2 gap-6">
              <div>
                <label class="block text-xs tracking-widest uppercase text-black/40 mb-2">Nombre</label>
                <input type="text" name="name" required class="w-full border-b-2 border-gray-200 py-3 focus:border-black outline-none transition bg-transparent text-sm" placeholder="Tu nombre" />
              </div>
              <div>
                <label class="block text-xs tracking-widest uppercase text-black/40 mb-2">Telefono</label>
                <input type="tel" name="phone" class="w-full border-b-2 border-gray-200 py-3 focus:border-black outline-none transition bg-transparent text-sm" placeholder="Tu telefono" />
              </div>
            </div>
            <div>
              <label class="block text-xs tracking-widest uppercase text-black/40 mb-2">Email</label>
              <input type="email" name="email" required class="w-full border-b-2 border-gray-200 py-3 focus:border-black outline-none transition bg-transparent text-sm" placeholder="tu@email.com" />
            </div>
            <div>
              <label class="block text-xs tracking-widest uppercase text-black/40 mb-2">Tipo de proyecto</label>
              <select name="project_type" class="w-full border-b-2 border-gray-200 py-3 focus:border-black outline-none transition bg-transparent text-sm text-gray-500">
                <option value="">Selecciona una opcion</option>
                <% contact.form_options.forEach(function(option) { %>
                  <option><%= option %></option>
                <% }); %>
              </select>
            </div>
            <div>
              <label class="block text-xs tracking-widest uppercase text-black/40 mb-2">Mensaje</label>
              <textarea rows="4" name="message" required class="w-full border-b-2 border-gray-200 py-3 focus:border-black outline-none transition bg-transparent text-sm resize-none" placeholder="Cuentanos sobre tu proyecto..."></textarea>
            </div>
            <button type="submit" class="w-full bg-black text-white py-4 text-sm tracking-widest uppercase hover:bg-gray-900 transition font-medium">
              Enviar Mensaje
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black text-white py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-4 gap-12 mb-12">
        <div class="md:col-span-2">
          <% if (settings.logo_image) { %>
            <img src="<%= settings.logo_image %>" alt="<%= settings.logo_text %>" class="h-10 w-auto mb-4" />
          <% } else { %>
            <h3 class="font-heading text-2xl font-bold tracking-widest mb-4"><%= settings.logo_text %></h3>
          <% } %>
          <div class="text-white/40 text-sm leading-relaxed max-w-md rich-content">
            <%- footer.description %>
          </div>
        </div>
        <div>
          <h4 class="text-xs tracking-widest uppercase mb-6 text-white/60">Navegacion</h4>
          <ul class="space-y-3">
            <% settings.nav_items.forEach(function(item) { %>
              <li><a href="<%= item.href %>" class="text-white/40 hover:text-white transition text-sm"><%= item.label %></a></li>
            <% }); %>
          </ul>
        </div>
        <div>
          <h4 class="text-xs tracking-widest uppercase mb-6 text-white/60">Siguenos</h4>
          <div class="flex gap-4">
            <% if (footer.social_facebook && footer.social_facebook !== '#') { %>
              <a href="<%= footer.social_facebook %>" target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            <% } %>
            <% if (footer.social_instagram && footer.social_instagram !== '#') { %>
              <a href="<%= footer.social_instagram %>" target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              </a>
            <% } %>
            <% if (footer.social_tiktok && footer.social_tiktok !== '#') { %>
              <a href="<%= footer.social_tiktok %>" target="_blank" rel="noopener noreferrer" class="w-10 h-10 border border-white/20 flex items-center justify-center hover:bg-white hover:text-black transition">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46 6.26 6.26 0 001.82-4.48V8.46a8.26 8.26 0 004.84 1.56V6.53a4.84 4.84 0 01-1.08.16z"/></svg>
              </a>
            <% } %>
          </div>
        </div>
      </div>
      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-white/30 text-xs"><%- footer.copyright %></p>
        <p class="text-white/30 text-xs"><%= footer.tagline %></p>
      </div>
    </div>
  </footer>

  <script>
    // Navbar scroll effect
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) {
        navbar.classList.add('bg-black/95', 'backdrop-blur-sm', 'shadow-lg');
        navbar.classList.remove('bg-transparent');
      } else {
        navbar.classList.remove('bg-black/95', 'backdrop-blur-sm', 'shadow-lg');
        navbar.classList.add('bg-transparent');
      }
    });

    // Mobile menu toggle
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });

    // Close mobile menu on link click
    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('hidden');
      });
    });

    // Gallery Carousel (mobile)
    const track = document.getElementById('galleryTrack');
    const dotsContainer = document.getElementById('galleryDots');
    const counter = document.getElementById('galleryCounter');
    const prevBtnG = document.getElementById('prevBtn');
    const nextBtnG = document.getElementById('nextBtn');
    if (track) {
      const slides = track.children;
      const total = slides.length;
      let current = 0;

      // Create dots
      for (let i = 0; i < total; i++) {
        const dot = document.createElement('button');
        dot.className = 'w-2.5 h-2.5 rounded-full transition-all duration-300 ' + (i === 0 ? 'bg-black w-6' : 'bg-black/20');
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }

      function goTo(index) {
        current = index;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        counter.textContent = (current + 1) + ' / ' + total;
        Array.from(dotsContainer.children).forEach((dot, i) => {
          dot.className = 'h-2.5 rounded-full transition-all duration-300 ' + (i === current ? 'bg-black w-6' : 'bg-black/20 w-2.5');
        });
      }

      prevBtnG.addEventListener('click', () => goTo(current > 0 ? current - 1 : total - 1));
      nextBtnG.addEventListener('click', () => goTo(current < total - 1 ? current + 1 : 0));

      // Touch swipe
      let startX = 0;
      track.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; }, { passive: true });
      track.addEventListener('touchend', (e) => {
        const diff = startX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 50) {
          if (diff > 0) nextBtnG.click();
          else prevBtnG.click();
        }
      }, { passive: true });

      // Auto-play
      let autoPlay = setInterval(() => nextBtnG.click(), 4000);
      track.parentElement.addEventListener('touchstart', () => clearInterval(autoPlay), { passive: true });
    }

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('slide-up');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('section > div').forEach(el => {
      observer.observe(el);
    });

    // Toast notification
    function showToast(message, success) {
      const existing = document.getElementById('toast');
      if (existing) existing.remove();
      const toast = document.createElement('div');
      toast.id = 'toast';
      toast.className = 'fixed top-6 right-6 z-[100] px-6 py-4 rounded-lg shadow-2xl text-sm font-medium transition-all duration-500 transform translate-x-full opacity-0 flex items-center gap-3 ' + (success ? 'bg-black text-white' : 'bg-red-600 text-white');
      toast.innerHTML = (success
        ? '<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'
        : '<svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>'
      ) + '<span>' + message + '</span>';
      document.body.appendChild(toast);
      requestAnimationFrame(() => {
        toast.classList.remove('translate-x-full', 'opacity-0');
        toast.classList.add('translate-x-0', 'opacity-100');
      });
      setTimeout(() => {
        toast.classList.remove('translate-x-0', 'opacity-100');
        toast.classList.add('translate-x-full', 'opacity-0');
        setTimeout(() => toast.remove(), 500);
      }, 4000);
    }

    // Contact form AJAX submission
    const contactForm = document.querySelector('form[action="/api/contact"]');
    if (contactForm) {
      contactForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const btn = this.querySelector('button[type="submit"]');
        const btnText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Enviando...';
        const formData = new FormData(this);
        const data = Object.fromEntries(formData.entries());
        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });
          if (res.ok) {
            showToast('Gracias por tu mensaje. Te contactaremos pronto.', true);
            this.reset();
          } else {
            showToast('Hubo un error al enviar tu mensaje. Intenta de nuevo.', false);
          }
        } catch (err) {
          showToast('Hubo un error al enviar tu mensaje. Intenta de nuevo.', false);
        }
        btn.disabled = false;
        btn.textContent = btnText;
      });
    }
  </script>

</body>
</html>
